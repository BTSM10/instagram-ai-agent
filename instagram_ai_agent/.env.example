# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# Groq API key — get yours free at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
# Gmail App Password — NOT your regular Gmail password.
# How to get one:
#   1. Go to myaccount.google.com/security
#   2. Enable 2-Step Verification (if not already on)
#   3. Search for "App passwords" in the search bar
#   4. Create an app password for "Mail" on "Mac"
#   5. Copy the 16-character code here (no spaces)
GMAIL_APP_PASSWORD=your_16_char_app_password_here

# Instagram login (optional — only needed for private or age-restricted accounts)
# INSTAGRAM_USERNAME=your_instagram_username
# INSTAGRAM_PASSWORD=your_instagram_password
